# EmailJS credentials — copy this file to ".env" and paste your own values.
# Get them from https://dashboard.emailjs.com  (Email Services / Email Templates / Account → API Keys)
VITE_EMAILJS_SERVICE_ID=your_service_id
VITE_EMAILJS_TEMPLATE_ID=your_template_id
VITE_EMAILJS_PUBLIC_KEY=your_public_key
